# --- Supabase (server-side only) ---
# Project Settings -> API. Use the SERVICE ROLE key here (not the anon key) —
# it bypasses Row Level Security so the backend can write freely. Never expose
# this key to the frontend/browser.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend ---
RESEND_API_KEY=
# Must be an address/domain you've verified in Resend.
FROM_EMAIL=Voice2Prompt <no-reply@voice2prompt.dev>

# --- Download links, per platform ---
DOWNLOAD_URL_MAC=https://github.com/anukool23/voice2prompt/releases
DOWNLOAD_URL_WINDOWS=https://github.com/anukool23/voice2prompt/releases

# --- CORS ---
# Comma-separated list of allowed origins, or "*" for all (fine while testing;
# tighten before going live, e.g. https://voice2prompt.app,https://www.voice2prompt.app)
CORS_ORIGINS=*
